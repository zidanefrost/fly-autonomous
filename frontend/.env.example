# Leave all of these unset to run the dashboard against bundled mock data
# (no cloud account needed). Fill them in to go live.

# Supabase project settings (Settings -> API in the Supabase dashboard)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Common prefix of the deployed Modal app's web endpoints — NOT a full URL.
# Modal gives each function its own subdomain (e.g.
# https://<you>--otp-weather-risk-trigger-refresh.modal.run), so set this to
# everything before "-trigger-refresh.modal.run" / "-ai-briefing.modal.run":
# VITE_WORKER_BASE_URL=https://<you>--otp-weather-risk
VITE_WORKER_BASE_URL=
